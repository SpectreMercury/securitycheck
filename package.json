{
  "name": "@error404/securitycheck",
  "version": "0.1.0",
  "description": "Pre-commit secret scanner. Blocks API keys, tokens, .env files, and private keys from leaking into git. Ships as a Claude Code skill and a standalone CLI / git hook.",
  "bin": {
    "securitycheck": "./bin/cli.js",
    "sec": "./bin/cli.js"
  },
  "main": "./lib/scan.js",
