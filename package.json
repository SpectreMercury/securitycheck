    "test": "node --test test/*.test.js",
    "scan": "node bin/cli.js scan"
  },
  "files": [
    "bin/",
    "lib/",
    "skill/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "security",
    "secrets",
    "pre-commit",
    "git-secrets",
    "secret-scan",
    "leak-detection",
    "gitignore",
    "git-hook",
    "husky",
    "lefthook",
    "claude-code",
    "claude-skill",
    "anthropic",
    "supply-chain"
  ],
